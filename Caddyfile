# =============================================================================
# Caddyfile — Duty Scheduler reverse proxy
# =============================================================================
# Development: serves on localhost with HTTP only.
# Production:  replace "localhost" with your real domain; Caddy will obtain
#              a Let's Encrypt TLS certificate automatically.
# =============================================================================

localhost {

    # ------------------------------------------------------------------
    # Security headers applied to every response
    # ------------------------------------------------------------------
    header {
        # Prevent the browser from inferring MIME types
        X-Content-Type-Options "nosniff"
        # Deny embedding in iframes from other origins
        X-Frame-Options "SAMEORIGIN"
        # Basic XSS filter for older browsers
        X-XSS-Protection "1; mode=block"
        # Only send the path in the Referer header when navigating to HTTPS
        Referrer-Policy "strict-origin-when-cross-origin"
        # Restrict powerful browser features
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        # Remove the server identity header
        -Server
    }

    # ------------------------------------------------------------------
    # API — FastAPI backend
    # ------------------------------------------------------------------
    handle /api/* {
        reverse_proxy api:8000 {
            # Pass real client IP to the backend
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # Health-check the upstream before forwarding
            health_uri     /health
            health_interval 15s
        }
    }

    # ------------------------------------------------------------------
    # Frontend — Next.js
    # All remaining paths (including client-side routes) go to the web service.
    # "handle" with a trailing /* is the correct Caddy catch-all.
    # ------------------------------------------------------------------
    handle /* {
        reverse_proxy web:3000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}


# =============================================================================
# Production template (uncomment and replace domain)
# =============================================================================
