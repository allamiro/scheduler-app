# =============================================================================
# Scheduler App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=scheduler_db
POSTGRES_USER=scheduler_user
POSTGRES_PASSWORD=change_me_strong_db_password

# --- Redis ---
# Leave blank to run without Redis auth (dev only).
# Set a strong password for any non-local deployment.
REDIS_PASSWORD=change_me_strong_redis_password

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_generate_a_real_secret

# --- Default admin account (created on first startup) ---
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_me_strong_admin_password
DEFAULT_ADMIN_EMAIL=admin@scheduler.local

# --- CORS (comma-separated list of allowed origins) ---
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# --- Frontend API URL (must be reachable from the user's browser) ---
# For local dev:  http://localhost:8001
# Through proxy:  http://localhost:8081
NEXT_PUBLIC_API_URL=http://localhost:8001

# --- Proxy ports (host ports the proxy listens on) ---
HTTP_PORT=8081
HTTPS_PORT=8444
